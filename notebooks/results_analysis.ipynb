    "## Visual Comparison — Real vs Synthetic Images\n",
    "Loads saved NIfTI volumes from the test job and shows a side-by-side grid:\n",
    "**Real MRI | Fake CT | Real CT | Fake MRI** for each ablation config.\n",
    "Suitable for direct use in the paper."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "afe38226",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[warn] Split file not found: ../splits/head_neck_split.json\n",
      "[missing] ../outputs/g0_baseline_cyclegan/head_neck\n",
      "  → Run test job and copy: kubectl cp <test-pod>:/data/ablation_outputs/outputs/ outputs/\n",
      "[missing] ../outputs/full_model/head_neck\n",
      "  → Run test job and copy: kubectl cp <test-pod>:/data/ablation_outputs/outputs/ outputs/\n",
      "No outputs found. Steps:\n",
      "  1. kubectl delete job test-hn && kubectl apply -f scripts/test_job.yaml\n",
      "  2. kubectl cp <test-pod>:/data/ablation_outputs/outputs/ outputs/\n"
     ]
    }
   ],
   "source": [
    "# ── Visual comparison: Real vs Synthetic ─────────────────────────────────────\n",
    "# Reads NIfTI volumes from OUTPUT_DIR/outputs/{config}/{anatomy}/{patient_id}/\n",
    "# Real MR/CT are loaded from the original paths in the split JSON.\n",
    "# Layout per row: Real MRI | Synthetic CT | Real CT | Synthetic MRI\n",
    "# Saves a publication-ready figure to figures/visual_comparison_{ANATOMY}.png\n",
    "\n",
    "import SimpleITK as sitk\n",
    "\n",
    "VIS_CONFIGS  = ['g0_baseline_cyclegan', 'full_model']\n",
    "OUTPUTS_DIR  = OUTPUT_DIR / 'outputs'   # written by test_multitask.py\n",
    "N_PATIENTS   = 3   # example patients per config\n",
    "\n",
    "# ── Helpers ───────────────────────────────────────────────────────────────────\n",
    "def _load_mid_slice(path: Path):\n",
    "    \"\"\"Load the middle axial slice from a NIfTI file. Returns None if missing.\"\"\"\n",
    "    if not Path(path).exists():\n",
    "        return None\n",
    "    try:\n",
    "        img = sitk.ReadImage(str(path))\n",
    "        arr = sitk.GetArrayFromImage(img).astype('float32')  # (Z, Y, X)\n",
    "        return arr[arr.shape[0] // 2]\n",
    "    except Exception as e:\n",
    "        print(f'  Could not load {Path(path).name}: {e}')\n",
    "        return None\n",
    "\n",
    "def _normalise(arr):\n",
    "    lo, hi = arr.min(), arr.max()\n",
    "    return (arr - lo) / (hi - lo + 1e-8)\n",
    "\n",
    "# ── Load split to get real image paths ───────────────────────────────────────\n",
    "split_path = OUTPUT_DIR / 'splits' / f'{ANATOMY}_split.json'\n",
    "real_paths: Dict[str, Dict[str, str]] = {}   # patient_id → {mr_path, ct_path}\n",
    "if split_path.exists():\n",
    "    with open(split_path) as fh:\n",
    "        split_data = json.load(fh)\n",
    "    for entry in split_data.get('test', []):\n",
    "        real_paths[entry['patient_id']] = {\n",
    "            'mr': entry['mr_path'],\n",
    "            'ct': entry['ct_path'],\n",
    "        }\n",
    "else:\n",
    "    print(f'[warn] Split file not found: {split_path}')\n",
    "\n",
    "# ── Gather rows ───────────────────────────────────────────────────────────────\n",
    "rows = []   # (config, patient_id, real_mr, synth_ct, real_ct, synth_mr)\n",
    "\n",
    "for cfg in VIS_CONFIGS:\n",
    "    cfg_dir = OUTPUTS_DIR / cfg / ANATOMY\n",
    "    if not cfg_dir.exists():\n",
    "        print(f'[missing] {cfg_dir}')\n",
    "        print(f'  → Run test job and copy: kubectl cp <test-pod>:/data/ablation_outputs/outputs/ outputs/')\n",
    "        continue\n",
    "\n",
    "    patients = sorted(cfg_dir.glob('*/'))[:N_PATIENTS]\n",
    "    for pat_dir in patients:\n",
    "        pid = pat_dir.name\n",
    "        synth_ct = _load_mid_slice(pat_dir / 'synthetic_ct.nii.gz')\n",
    "        synth_mr = _load_mid_slice(pat_dir / 'synthetic_mr.nii.gz')\n",
    "\n",
    "        # Real images: from split JSON (original data paths)\n",
    "        rp = real_paths.get(pid, {})\n",
    "        real_mr = _load_mid_slice(rp.get('mr')) if rp else None\n",
    "        real_ct = _load_mid_slice(rp.get('ct')) if rp else None\n",
    "\n",
    "        if synth_ct is None or synth_mr is None:\n",
    "            print(f'  [incomplete] {cfg}/{pid} — missing synthetic_ct or synthetic_mr')\n",
    "            continue\n",
    "\n",
    "        rows.append((cfg, pid, real_mr, synth_ct, real_ct, synth_mr))\n",
    "\n",
    "# ── Plot ──────────────────────────────────────────────────────────────────────\n",
    "if not rows:\n",
    "    print('No outputs found. Steps:')\n",
    "    print('  1. kubectl delete job test-hn && kubectl apply -f scripts/test_job.yaml')\n",
    "    print('  2. kubectl cp <test-pod>:/data/ablation_outputs/outputs/ outputs/')\n",
    "else:\n",
    "    col_titles = ['Real MRI', 'Synthetic CT', 'Real CT', 'Synthetic MRI']\n",
    "    n_rows = len(rows)\n",
    "    n_cols = 4\n",
    "\n",
    "    fig, axes = plt.subplots(n_rows, n_cols, figsize=(n_cols * 3.5, n_rows * 3.2))\n",
    "    if n_rows == 1:\n",
    "        axes = axes[np.newaxis, :]\n",
    "\n",
    "    for row_idx, (cfg, pid, real_mr, synth_ct, real_ct, synth_mr) in enumerate(rows):\n",
    "        images = [real_mr, synth_ct, real_ct, synth_mr]\n",
    "        for col_idx, img in enumerate(images):\n",
    "            ax = axes[row_idx, col_idx]\n",
    "            if img is not None:\n",
    "                ax.imshow(_normalise(img), cmap='gray', origin='lower')\n",
    "            else:\n",
    "                ax.text(0.5, 0.5, 'N/A', ha='center', va='center',\n",
    "                        transform=ax.transAxes, fontsize=10, color='gray')\n",
    "            ax.axis('off')\n",
    "            if row_idx == 0:\n",
    "                ax.set_title(col_titles[col_idx], fontsize=11, fontweight='bold', pad=6)\n",
    "\n",
    "        # Row label: config name on first patient row for that config\n",
    "        axes[row_idx, 0].set_ylabel(\n",
    "            f'{cfg}\\n{pid}', fontsize=8, rotation=0, labelpad=80, va='center'\n",
    "        )\n",
    "\n",
    "    fig.suptitle(f'Real vs Synthetic — {ANATOMY.upper()}', fontsize=13, fontweight='bold', y=1.01)\n",
    "    plt.tight_layout()\n",
    "\n",
    "    save_path = FIGURES_DIR / f'visual_comparison_{ANATOMY}.png'\n",
    "    fig.savefig(save_path, dpi=150, bbox_inches='tight')\n",
    "    print(f'Figure saved to: {save_path}')\n",
    "    plt.show()\n"
   ]
  },
